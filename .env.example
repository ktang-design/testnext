# Copy to .env and adjust. Never commit real secrets.
NODE_ENV=development
PORT=3000

# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Database (libSQL / Turso).
# Local dev: a file URL is fine and persists to disk.
TURSO_DATABASE_URL=file:./data/dev.db
# Production (Vercel): a Turso remote URL + auth token instead, e.g.
#   TURSO_DATABASE_URL=libsql://<your-db>.turso.io
#   TURSO_AUTH_TOKEN=<token from: turso db tokens create <your-db>>
TURSO_AUTH_TOKEN=

# Seed the demo account (demo@stacksnext.com / Password123!) on first boot.
SEED_DEMO_USER=true
